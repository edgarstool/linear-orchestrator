# Copied / overlaid with ~/.hermes/.env at runtime; this file is documentation only.
LINEAR_API_KEY=lin_api_xxxx
LINEAR_WEBHOOK_SECRET=lin_wh_xxxx                   # workspace webhook signing secret（必備）
LINEAR_OAUTH_WEBHOOK_SECRET=lin_wh_oauth_app_xxxx   # Hermes Agent App 頁的 Signing secret（委派必備）
HERMES_PATH=/home/edgar/.local/bin/hermes
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8645
HERMES_TIMEOUT_SEC=180
DEFAULT_MODEL=
# optional: comma-separated Linear identifiers that this agent watches
AGENT_LINEAR_USER_ID=
